# Target: GL.iNet GL-MT3600BE (MediaTek MT7987)
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_mt7987=y
CONFIG_TARGET_mediatek_mt7987_DEVICE_glinet_gl-mt3600be=y

# Base config
CONFIG_TARGET_BOARD="mediatek"
CONFIG_TARGET_SUBTARGET="mt7987"
CONFIG_TARGET_PROFILE="DEVICE_glinet_gl-mt3600be"

# PassWall 2 and Xray
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_luci-app-passwall2_I18N_ru=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-socket=y
